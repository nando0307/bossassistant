# Git
.git/
.gitignore

# Python virtual env (rebuilt fresh inside the image)
.venv/
venv/
env/

# Python bytecode + caches
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Secrets — NEVER ship into an image
.env
.env.*

# R&D and dev-only — not needed at runtime
notebooks/
tests/

# Frontend deploys separately on Vercel
frontend/

# Editor / OS junk
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# Logs
*.log
